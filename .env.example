PORT=3000
# 127.0.0.1 = bind localhost + restrict API/SSE/MCP to local clients
# 0.0.0.0     = bind all interfaces, no API/SSE/MCP restriction
HOST=127.0.0.1
DB_PATH=data.sqlite

# Optional: OpenAI-compatible API for AI filter (when a filter prompt is set)
# LLM_BASE_URL=https://api.openai.com
# LLM_API_KEY=
# LLM_MODEL_NAME=gpt-4o-mini

# WechatRss API
# WECHATRSS_API_KEY=
# WECHATRSS_API_SECRET=